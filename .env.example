# Hugging Face access token for the gated HackAPrompt dataset.
# Create a token at https://huggingface.co/settings/tokens after getting dataset access.
HF_TOKEN=

# Alternative token env var supported by Hugging Face tooling.
HUGGINGFACE_HUB_TOKEN=

# Optional local dataset export fallback.
# Supported formats: CSV, JSON, JSONL, Parquet.
HACKAPROMPT_LOCAL_FILE=

# Local OpenAI-compatible Qwen embedding endpoint.
QWEN_EMBEDDING_BASE_URL=http://localhost:6620/v1
QWEN_EMBEDDING_MODEL=qwen3-embedding
